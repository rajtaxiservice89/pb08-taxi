generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default("global")
  heroTitle String   @default("Reliable & Safe Taxi Service in Jalandhar")
  heroText  String   @default("Book a comfortable ride today. We offer airport transfers, outstation trips, and local rentals at the best prices.")
  phone1    String   @default("9056273306")
  phone2    String   @default("9888079736")
  email     String   @default("info@rajtaxi.com")
  address   String   @default("Main Street, City Center")
  whatsapp1 String   @default("9056273306")
  whatsapp2 String   @default("9888079736")
  secretPin String   @default("333725")
  updatedAt DateTime @updatedAt
}

model Booking {
  id            String   @id @default(uuid())
  customerName  String
  customerPhone String
  pickup        String
  pickupLat     Float?
  pickupLng     Float?
  destination   String
  destLat       Float?
  destLng       Float?
  date          String
  time          String
  vehicleType   String
  passengers    Int
  notes         String?
  estimatedFare Float?
  status        String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  waDriverStatus   String   @default("none") // none, pending, success, error
  waCustomerStatus String   @default("none") // none, pending, success, error
  assignedDriverId String?
  assignedDriver   DriverProfile? @relation(fields: [assignedDriverId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DriverProfile {
  id                    String   @id @default(uuid())
  name                  String
  contact               String   @unique
  password              String?  // Made optional for existing applications, but required for login
  address               String
  aadharNumber          String   @unique
  licenseNumber         String   @unique
  carRegistration       String
  chassisNumber         String
  carName               String
  selfieUrl             String?
  aadharFrontUrl        String?
  aadharBackUrl         String?
  drivingLicenseUrl     String?
  carRegistrationDocUrl String?
  policeVerificationUrl String?
  createdBy             String   @default("driver") // "admin" or "driver"
  status                String   @default("PENDING") // PENDING, APPROVED, REJECTED
  bookings              Booking[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model FareSetting {
  id          String   @id @default("global")
  appCost     Float    @default(50)
  driverCost  Float    @default(50)
  baseFare    Float    @default(50)
  distanceTiers String @default("[{\"min\": 0, \"max\": 5, \"rate\": 20}, {\"min\": 5, \"max\": 9999, \"rate\": 15}]")
  updatedAt   DateTime @updatedAt
}

model LocationApi {
  id        String   @id @default(uuid())
  provider  String   
  apiKey    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
